# ============================================================
# StockPro SN — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# IMPORTANT : Ne jamais committer .env dans git
# ============================================================

# ── Sécurité ─────────────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGEZ-MOI-AVEC-UNE-VRAIE-CLE-SECRETE-LONGUE

# ── Mode ─────────────────────────────────────────────────────────────────────
DEBUG=False
ALLOWED_HOSTS=votre-domaine.sn,www.votre-domaine.sn

# ── Base de données PostgreSQL ────────────────────────────────────────────────
# Option 1 — URL complète (Render, Railway, Heroku…)
# DATABASE_URL=postgresql://user:password@host:5432/stockpro_db

# Option 2 — Paramètres séparés
DB_ENGINE=django.db.backends.postgresql
DB_NAME=stockpro_db
DB_USER=stockpro_user
DB_PASSWORD=mot-de-passe-fort-ici
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# ── URL admin (sécurité par obscurité) ───────────────────────────────────────
# Choisir une URL non devinable — ex: admin-xyz123/
ADMIN_URL=gestion-plateforme/

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.votre-fournisseur.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@votre-domaine.sn
EMAIL_HOST_PASSWORD=mot-de-passe-email
DEFAULT_FROM_EMAIL=StockPro SN <noreply@votre-domaine.sn>

# ── Développement local uniquement ───────────────────────────────────────────
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
